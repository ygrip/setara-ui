{
  "name": "setara-ui",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ygrip/setara-ui.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:mock": "VITE_MOCK=true vite dev",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:ui": "node --test tests/*.test.mjs",
    "generate:types": "openapi-typescript ${SETARA_API_URL:-http://localhost:8080}/q/openapi -o src/lib/api/openapi.d.ts && echo 'Types generated → src/lib/api/openapi.d.ts'",
    "check:contract": "node scripts/check-contract.mjs",
    "check:openapi": "tsx scripts/check-openapi.ts",
    "build:demo": "cross-env VITE_MOCK=true BUILD_TARGET=demo vite build"
  },
  "overrides": {
    "cookie": "^0.7.0"
  },
  "dependencies": {
    "@melt-ui/svelte": "^0.86.6",
    "@revolist/svelte-datagrid": "^4.22.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tanstack/table-core": "^8.21.3",
    "bits-ui": "^2.18.1",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "d3-interpolate": "^3.0.1",
    "formsnap": "^2.0.1",
    "highlight.js": "^11.11.1",
    "layerchart": "^1.0.13",
    "marked": "^18.0.4",
    "flowbite": "3.1.2",
    "flowbite-svelte": "^1.0.0",
    "svelte": "^5.17.3",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@tailwindcss/vite": "^4.1.4",
    "@types/d3-time": "^3.0.4",
    "@types/node": "^25.9.1",
    "tailwindcss": "^4.1.4",
    "class-validator": "^0.14.4",
    "cross-env": "^10.1.0",
    "openapi-typescript": "^7.8.0",
    "svelte-check": "^4.1.3",
    "typescript": "^5.7.2",
    "valibot": "^1.4.1"
  }
}
